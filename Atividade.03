        private void Form1_Load4(object sender, EventArgs e)
        {
            int x1 = 0;
            int y1 = 0;

            int x2 = 5;
            int y2 = 0;

            double distancia;

            distancia = Math.Sqrt(Math.Pow(x2 - x1, 2) + Math.Pow(y2 - y1, 2));

            MessageBox.Show("DistŌncia: " + distancia);
        }

